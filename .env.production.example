# ============================================================================
# PRODUCTION ENVIRONMENT CHECKLIST — GrowwMatics AI
# ============================================================================
# Copy to .env (or set in the host's env panel) and fill every REQUIRED value.
# Items marked [BREAKS CUSTOMERS] are the ones that fail visibly on day one.
# Generated 2026-07-07 from the pre-production audit.
# ============================================================================

# --- Core ---------------------------------------------------------------
# Must be a production Atlas cluster with a dedicated user (NOT the seed
# script's hardcoded credentials — rotate that password before launch).
MONGODB_URI=

# REQUIRED. Long random secret (e.g. `openssl rand -hex 48`). Signs all auth
# tokens AND is the bearer token for /api/automation/trigger — never reuse
# the dev value.
JWT_SECRET=
SESSION_SECRET=
NEXTAUTH_SECRET=
GOOGLE_TOKEN_SECRET=

# --- Public URLs [BREAKS CUSTOMERS if left unset] -------------------------
# All three must be the real HTTPS domain. NEXT_PUBLIC_BASE_URL is used to
# build review-tracking links sent to customers over WhatsApp — if unset it
# falls back to http://localhost:3000 (src/services/inngest/functions.ts).
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com

# --- Google OAuth / GBP [BREAKS CUSTOMERS] --------------------------------
# 1. Add https://yourdomain.com/api/auth/google/callback as an authorized
#    redirect URI in Google Cloud Console.
# 2. Move the OAuth consent screen from "Testing" to "In production" —
#    in Testing mode every refresh token expires after 7 days, breaking all
#    customer GBP connections weekly. GBP scopes need Google verification;
#    start this early, it takes days-to-weeks.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback
GOOGLE_MAPS_API_KEY=

# --- WhatsApp: Meta Cloud API [BREAKS CUSTOMERS] --------------------------
# The dev setup used Twilio's shared sandbox number (+14155238886) which is
# unusable in production. Sends auto-fall-back to Twilio while the two
# starred keys below are empty — fill them to actually go live on Meta.
WHATSAPP_PROVIDER=meta
META_WHATSAPP_ACCESS_TOKEN=            # * permanent system-user token
META_WHATSAPP_PHONE_NUMBER_ID=         # *
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_APP_SECRET=                       # required to verify inbound webhooks
META_WEBHOOK_VERIFY_TOKEN=             # any random string; set same in Meta app
# Approved utility template for business-initiated messages outside the 24h
# window; must have exactly one {{1}} body variable. Needs Meta approval.
META_UTILITY_TEMPLATE_NAME=
META_TEMPLATE_LANGUAGE=en
# META_GRAPH_API_VERSION=v23.0

# Twilio — only if kept as a paid fallback sender (a purchased number, not
# the sandbox). Otherwise leave empty.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Background jobs: Inngest Cloud [BREAKS CUSTOMERS] --------------------
# Do NOT set INNGEST_DEV in production. Create an Inngest Cloud app and use
# its real keys; reminders, scheduled posts and GBP sync all run through it.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Email ----------------------------------------------------------------
# Resend: verify your domain, then set a from-address on it. The default
# fallback (onboarding@resend.dev) only delivers to the account owner.
RESEND_API_KEY=
RESEND_FROM_EMAIL="GrowwMatics AI <noreply@yourdomain.com>"
# SendGrid powers review-request emails; without it they are silently mocked.
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=GrowwMatics AI

# --- Billing: Razorpay LIVE mode ------------------------------------------
# Use live keys (rzp_live_...). Configure the webhook in the Razorpay
# dashboard to POST https://yourdomain.com/api/webhook/razorpay with the
# same secret. The single sellable plan is managed by the super admin
# (Admin → Subscriptions); its Razorpay Plan is created automatically for
# the configured price. RAZORPAY_PLAN_ID_PRO is only a legacy fallback used
# until the super admin saves the plan once — safe to leave empty.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PRO=

# --- AI / data providers ----------------------------------------------------
GROQ_API_KEY=
OPENAI_API_KEY=
SERPAPI_KEY=
REVIEW_PROVIDER=serpapi
MAX_REVIEWS_PER_AUDIT=50
# Thumbnail image generation. Two accepted key types (auto-routed by prefix):
#   nb_…        -> NanoBanana API (nananobanana.com), returns a hosted URL
#   AQ.… / AIzaSy… -> Google AI Studio / Gemini image model ("Nano Banana")
# EITHER WAY image generation is PAID: a NanoBanana plan, or a Google project
# with BILLING ENABLED (the free tier returns 429 / no image quota).
NANOBANANA_API_KEY=
# Optional override of the Gemini image model (default: gemini-2.5-flash-image).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Safety flags — keep these exact values in production -------------------
# true would skip plan-limit gating on audits.
AUDIT_BYPASS_MODE=false
# Master switch for writing to REAL Google Business Profiles (posts + review
# replies). Keep false until verified on a test account. See src/lib/gbpSafety.ts.
GBP_LIVE_WRITES_ENABLED=false
# NODE_ENV=production is what disables the dev auth bypass in several API
# routes and the dev OTP console logging — make sure the host builds with it
# (next build / next start do this automatically).
