# Base URL of the Next.js backend (no trailing slash).
# For local dev this must be reachable FROM THE DEVICE — localhost won't work
# from a physical phone. Use your machine's LAN IP or a tunnel:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
#   EXPO_PUBLIC_API_URL=https://your-tunnel.ngrok-free.app
EXPO_PUBLIC_API_URL=
